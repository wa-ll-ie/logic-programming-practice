algoritmo "idade"

var
  nome1, nome2: caractere
  idade1, idade2: inteiro

inicio

  escreval ("Dados da primeira pessoa: ")
  escreval ("Nome: ")
  leia(nome1)
  escreval("Idade: ")
  leia(idade1)
  escreval ("Dados da segunda pessoa: ")
  escreval ("Nome: ")
  leia(nome2)
  escreval("Idade: ")
  leia(idade2)


  escreval ("A idade média de " nome1 " e " nome2 " é de " (idade1 + idade2) / 2)

fimalgoritmo
