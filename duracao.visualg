algoritmo "duracao"

var
  duracao, horas, resto, minutos, segundos: inteiro

inicio

  escreval("Digite a duração em segundos: ")
  leia(duracao)

  horas <- duracao \ 3600
  resto <- duracao mod 3600

  minutos <- resto \ 60
  segundos <- resto mod 60

  escreval(horas)
  escreval(resto)

  escreval(horas, ":", minutos, ":", segundos)

fimalgoritmo
