algoritmo "terreno"

var
  base, altura, perimetro, area, diagonal: real

inicio

  escreval ("Base do retangulo = ")
  leia (base)
  escreval ("Altura do retangulo =")
  leia (altura)

  area <- base*altura
  perimetro <- 2 * base + 2 * altura
  diagonal <- raizq (exp(base, 2) + exp(altura, 2))

  escreval ("Area = ", area:3:4)
  escreval ("Perimetro = ", perimetro:3:4)
  escreval ("Diagonal = ", diagonal:2:4)

fimalgoritmo
