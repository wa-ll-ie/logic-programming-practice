algoritmo "baskara"

var

  a, b, c, delta, x1, x2: real

inicio

  a <- 1
  b <- 3
  C <- 4
  delta <- exp(b, 2) - (4 * a * c)

  se (a = 0) ou (delta < 0) entao
     escreval("Está equação não possui raizes reais")

  senao
      x1 <- (-b + raizq(delta)) / (2 * a)
      x2 <- (-b - raizq(delta)) / (2 * a)

      escreval("X1 = ", x1:1:4)
      escreval("X2 = ", x2:1:4)

  fimse


fimalgoritmo


